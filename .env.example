# API base URL (no trailing slash). Get it after deploying infra:
#   cd diydash-infra/terraform && terraform output -raw api_base_url
# Copy to .env.local and set your URL. Restart dev server after changing.
# Fix for "NetworkError when attempting to fetch resource": also run terraform apply so CORS includes X-User-Email.
# VITE_API_BASE_URL=https://YOUR_API_ID.execute-api.us-west-2.amazonaws.com/prod
